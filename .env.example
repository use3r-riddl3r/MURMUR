# Конфигурация MURMUR - скопируйте это в .env для локальной настройки
# Примечание: приложение в настоящее время не требует файла .env, так как все API общедоступны/бесплатны
# Этот файл документирует доступные параметры конфигурации для будущего улучшения

# =============================================================================
# КОНФИГУРАЦИЯ КАРТЫ
# =============================================================================

# Центральные координаты для начального представления карты [lat, lon]
MAP_CENTER_LAT=20
MAP_CENTER_LON=0

# Начальный уровень масштабирования (1-19)
MAP_ZOOM=2

# Уровень масштабирования плитки для географического разбиения (6 = ~64 плитки, покрывающие мир)
TILE_ZOOM=6

# =============================================================================
# ИСТОЧНИКИ ДАННЫХ - КОНЕЧНЫЕ ТОЧКИ API (Все общедоступны/бесплатны)
# =============================================================================

# OpenStreetMap Overpass API
# Документация: https://overpass-api.de/
# Аутентификация не требуется, ограничение: ~2 запр./сек
OSM_OVERPASS_API=https://overpass-api.de/api/interpreter

# OpenStreetMap Nominatim (Геокодирование)
# Документация: https://nominatim.openstreetmap.org/
# Аутентификация не требуется, ограничение: 1 запр./сек
OSM_NOMINATIM_API=https://nominatim.openstreetmap.org/

# Transport for London Unified API (Только Великобритания, TfL JamCam)
# Документация: https://api.tfl.gov.uk/
# Аутентификация не требуется, ограничение: 15 запр./мин
TFL_API=https://api.tfl.gov.uk/

# Французский портал открытых данных (data.gouv.fr)
# Документация: https://www.data.gouv.fr/
# Аутентификация не требуется
FRANCE_DATA_GOV_API=https://www.data.gouv.fr/api/

# =============================================================================
# ИНСТРУМЕНТЫ OSINT (Опционально - используется для ссылок расследования камер)
# =============================================================================

# Shodan (опционально: используйте бесплатный уровень или добавьте API ключ)
# Документация: https://www.shodan.io/
# Бесплатный уровень: API ключ не требуется для базовых поисков
SHODAN_API_BASE=https://www.shodan.io/

# ZoomEye (опционально)
# Документация: https://www.zoomeye.org/
# Бесплатный уровень: Аутентификация не требуется для базовых поисков
ZOOMEYE_API_BASE=https://www.zoomeye.org/

# FOFA - Поисковая система кибербезопасности (опционально)
# Документация: https://fofa.info/
# Бесплатный уровень: доступен, ограничено 100 запросами/день
FOFA_API_BASE=https://fofa.info/

# Insecam - каталог небезопасных камер (опционально)
# Документация: http://insecam.org/
INSECAM_API_BASE=http://insecam.org/

# =============================================================================
# АНАЛИТИКА (Опционально)
# =============================================================================

# Google Analytics Measurement ID (опционально, для развертывания)
GOOGLE_ANALYTICS_ID=

# Plausible Analytics Domain (опционально, более приватная альтернатива)
PLAUSIBLE_DOMAIN=

# =============================================================================
# РАЗРАБОТКА
# =============================================================================

# Уровень логирования: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Включить режим разработки (подробное логирование, показать границы плиток и т.д.)
DEVELOPMENT_MODE=false

# Локальный порт сервера для разработки
LOCAL_SERVER_PORT=8080

# =============================================================================
# РАЗВЕРТЫВАНИЕ
# =============================================================================

# Имя репозитория GitHub Pages (для определения путей активов)
GITHUB_REPO_NAME=MURMUR

# Имя пользователя GitHub (для создания URL развертывания)
GITHUB_USERNAME=

# Пользовательский домен (опционально, для пользовательского домена GitHub Pages)
CUSTOM_DOMAIN=

# =============================================================================
# ПРИМЕЧАНИЯ
# =============================================================================

# - Все указанные конечные точки API общедоступны и совместимы со свободным уровнем
# - В настоящее время для основного функционала не требуются учетные данные или ключи API
# - Этот файл предназначен для справочника и расширения в будущем
# - Текущая реализация использует эти конечные точки непосредственно в index.html
# - Рассмотрите возможность рефакторинга для загрузки из этого файла конфигурации для развертывания в производстве
# - Подробные инструкции по конфигурации см. в DEPLOY.md и README.md
